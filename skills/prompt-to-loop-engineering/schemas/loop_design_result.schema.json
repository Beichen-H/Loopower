{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://meta-skills-library.dev/schemas/loop_design_result.schema.json",
  "title": "Loop Design Result",
  "type": "object",
  "required": [
    "disposition",
    "task_contract",
    "loop_spec",
    "one_shot_validation_plan",
    "assumptions",
    "missing_inputs",
    "validation_report",
    "rejected_alternatives",
    "build_report"
  ],
  "properties": {
    "disposition": {
      "enum": [
        "one_shot",
        "workflow",
        "agent_loop",
        "needs_input",
        "unsupported",
        "rejected"
      ]
    },
    "task_contract": { "$ref": "#/$defs/task_contract" },
    "loop_spec": {
      "oneOf": [
        { "type": "null" },
        { "$ref": "loop_spec.schema.json" }
      ]
    },
    "one_shot_validation_plan": {
      "oneOf": [
        { "type": "null" },
        { "$ref": "#/$defs/one_shot_validation_plan" }
      ]
    },
    "assumptions": { "type": "array" },
    "missing_inputs": { "type": "array" },
    "validation_report": { "$ref": "#/$defs/validation_report" },
    "rejected_alternatives": { "type": "array" },
    "build_report": { "$ref": "#/$defs/build_report" }
  },
  "allOf": [
    {
      "if": { "properties": { "disposition": { "const": "one_shot" } } },
      "then": {
        "properties": {
          "loop_spec": { "type": "null" },
          "one_shot_validation_plan": { "$ref": "#/$defs/one_shot_validation_plan" },
          "build_report": {
            "properties": { "status": { "const": "no_loop_needed" } }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "disposition": { "enum": ["workflow", "agent_loop"] }
        }
      },
      "then": {
        "properties": {
          "loop_spec": { "$ref": "loop_spec.schema.json" },
          "one_shot_validation_plan": { "type": "null" },
          "build_report": {
            "properties": { "status": { "const": "spec_ready" } }
          }
        }
      }
    },
    {
      "if": { "properties": { "disposition": { "const": "needs_input" } } },
      "then": {
        "properties": {
          "loop_spec": { "type": "null" },
          "one_shot_validation_plan": { "type": "null" },
          "build_report": {
            "properties": { "status": { "const": "needs_input" } }
          }
        }
      }
    },
    {
      "if": { "properties": { "disposition": { "const": "unsupported" } } },
      "then": {
        "properties": {
          "loop_spec": { "type": "null" },
          "one_shot_validation_plan": { "type": "null" },
          "build_report": {
            "properties": { "status": { "const": "unsupported" } }
          }
        }
      }
    },
    {
      "if": { "properties": { "disposition": { "const": "rejected" } } },
      "then": {
        "properties": {
          "loop_spec": { "type": "null" },
          "one_shot_validation_plan": { "type": "null" },
          "build_report": {
            "properties": { "status": { "const": "rejected" } }
          }
        }
      }
    }
  ],
  "additionalProperties": false,
  "$defs": {
    "one_shot_validation_plan": {
      "type": "object",
      "required": ["execution_count", "cycle", "checks"],
      "properties": {
        "execution_count": { "const": 1 },
        "cycle": { "type": "null" },
        "checks": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["id", "type", "verifies"],
            "properties": {
              "id": { "type": "string", "minLength": 1 },
              "type": { "const": "deterministic" },
              "verifies": {
                "type": "array",
                "minItems": 1,
                "items": { "type": "string", "minLength": 1 },
                "uniqueItems": true
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "task_contract": {
      "type": "object",
      "required": [
        "id",
        "version",
        "goal",
        "deliverables",
        "acceptance_criteria",
        "constraints",
        "non_goals",
        "assumptions",
        "missing_inputs",
        "risk",
        "scope_change_policy"
      ],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "version": { "type": "integer", "minimum": 1 },
        "goal": { "type": "string", "minLength": 1 },
        "deliverables": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["id", "name", "format", "destination"]
          }
        },
        "acceptance_criteria": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": [
              "id",
              "requirement",
              "mandatory",
              "verification_method",
            "evidence_requirements"
            ],
            "properties": {
              "verification_method": {
                "enum": [
                  "deterministic_check",
                  "test",
                  "schema",
                  "source_check",
                  "model_evaluator",
                  "human_review"
                ]
              },
              "evidence_requirements": {
                "type": "array",
                "minItems": 1,
                "items": { "type": "string", "minLength": 1 },
                "uniqueItems": true
              }
            }
          }
        },
        "constraints": { "type": "array" },
        "non_goals": { "type": "array" },
        "assumptions": { "type": "array" },
        "missing_inputs": { "type": "array" },
        "risk": {
          "type": "object",
          "required": [
            "level",
            "side_effects",
            "sensitive_data",
            "irreversible_actions"
          ],
          "properties": {
            "level": { "enum": ["low", "medium", "high", "critical"] },
            "side_effects": { "type": "array" },
            "sensitive_data": { "type": "array" },
            "irreversible_actions": { "type": "array" }
          },
          "additionalProperties": false
        },
        "scope_change_policy": { "type": "object" }
      },
      "additionalProperties": false
    },
    "validation_report": {
      "type": "object",
      "required": ["valid", "errors", "warnings", "assumptions"],
      "properties": {
        "valid": { "type": "boolean" },
        "errors": { "type": "array" },
        "warnings": { "type": "array" },
        "assumptions": { "type": "array" }
      },
      "additionalProperties": false
    },
    "build_report": {
      "type": "object",
      "required": [
        "status",
        "reason",
        "execution_performed",
        "user_task_passed",
        "generated_spec_ref",
        "validation_report_ref",
        "missing_inputs",
        "unsupported_capabilities",
        "policy_rejections"
      ],
      "properties": {
        "status": {
          "enum": [
            "spec_ready",
            "no_loop_needed",
            "needs_input",
            "unsupported",
            "rejected"
          ]
        },
        "reason": { "type": "string", "minLength": 1 },
        "execution_performed": { "const": false },
        "user_task_passed": { "const": false },
        "generated_spec_ref": { "type": ["string", "null"] },
        "validation_report_ref": { "type": ["string", "null"] },
        "missing_inputs": { "type": "array" },
        "unsupported_capabilities": { "type": "array" },
        "policy_rejections": { "type": "array" }
      },
      "additionalProperties": false
    }
  }
}
