{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://meta-skills-library.dev/schemas/loop_spec.schema.json",
  "title": "LoopSpec v4-compatible portable contract",
  "type": "object",
  "required": [
    "spec_id",
    "version",
    "created_from_request",
    "task_contract_ref",
    "architecture",
    "runtime_binding",
    "state",
    "context",
    "control_flow",
    "transition_policy",
    "tools",
    "evaluation",
    "termination",
    "termination_control",
    "policy_registry",
    "policies",
    "delegation",
    "artifacts",
    "threshold_register",
    "validation"
  ],
  "properties": {
    "spec_id": { "type": "string", "minLength": 1 },
    "version": { "type": "integer", "minimum": 1 },
    "skill_version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "knowledge_contract": { "type": "string", "minLength": 1 },
    "contract_registry": { "type": "object" },
    "task_contract": { "type": "object" },
    "created_from_request": { "type": "string", "minLength": 1 },
    "task_contract_ref": { "type": "string", "minLength": 1 },
    "architecture": {
      "type": "object",
      "required": [
        "mode",
        "execution_patterns",
        "topology",
        "control_gates",
        "domain_compositions",
        "cross_cutting_policies",
        "rationale"
      ],
      "properties": {
        "mode": { "enum": ["workflow", "agent_loop"] },
        "execution_patterns": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "enum": ["prompt_chain", "tool_use", "plan_execute_replan", "evaluator_optimizer"] }
        },
        "topology": {
          "type": "object",
          "required": ["type"],
          "properties": {
            "type": { "enum": ["linear", "routed", "parallel", "orchestrator_workers", "graph_state_machine"] },
            "parallel_mode": { "type": ["string", "null"] }
          },
          "additionalProperties": false
        },
        "control_gates": {
          "type": "array",
          "uniqueItems": true,
          "items": { "enum": ["human_approval", "independent_review", "policy_check"] }
        },
        "domain_compositions": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        },
        "cross_cutting_policies": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "enum": ["recovery", "checkpointing", "observability", "budget_control", "scope_control"] }
        },
        "rationale": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "runtime_binding": {
      "type": "object",
      "required": ["capabilities_snapshot", "required_capabilities", "capability_mismatches"],
      "properties": {
        "capabilities_snapshot": { "$ref": "loop_design_request.schema.json#/properties/runtime_capabilities" },
        "required_capabilities": { "$ref": "#/$defs/capability_requirements" },
        "capability_mismatches": { "type": "array", "maxItems": 0 }
      },
      "additionalProperties": false
    },
    "execution_governance": {
      "description": "Required for persisted GO-phase .codex-loop scaffolds and optional for design-only LoopSpecs. The scaffold validator enforces it before execution.",
      "type": "object",
      "required": [
        "runtime_mode",
        "scheduler",
        "inline_execution_policy",
        "required_evidence",
        "linear_fulfillment_plugins"
      ],
      "properties": {
        "runtime_mode": { "const": "COOPERATIVE_GOVERNANCE" },
        "scheduler": { "const": "codex_loop_dag" },
        "inline_execution_policy": { "const": "forbidden_for_subagent_nodes" },
        "required_evidence": {
          "type": "object",
          "required": ["activation", "handoff", "completion"],
          "properties": {
            "activation": { "const": true },
            "handoff": { "const": true },
            "completion": { "const": true }
          },
          "additionalProperties": false
        },
        "linear_fulfillment_plugins": {
          "type": "object",
          "required": ["scheduler_takeover", "allowed_role"],
          "properties": {
            "scheduler_takeover": { "const": "forbidden" },
            "allowed_role": { "const": "node_scoped_atomic_capability" }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "state": { "type": "object" },
    "context": { "type": "object" },
    "control_flow": {
      "type": "object",
      "required": [
        "entry_node",
        "edge_selection_policy",
        "nodes",
        "edges",
        "cycles",
        "terminal_nodes"
      ],
      "properties": {
        "entry_node": { "type": "string", "minLength": 1 },
        "edge_selection_policy": {
          "type": "object",
          "required": ["priority_order", "match_policy", "equal_priority"],
          "properties": {
            "priority_order": { "const": "lower_first" },
            "match_policy": { "const": "first_match" },
            "equal_priority": { "const": "require_explicit_tie_breaker" }
          },
          "additionalProperties": false
        },
        "nodes": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/node" }
        },
        "edges": {
          "type": "array",
          "items": { "$ref": "#/$defs/edge" }
        },
        "cycles": {
          "type": "array",
          "items": { "$ref": "#/$defs/cycle" }
        },
        "terminal_nodes": {
          "type": "object",
          "required": [
            "passed",
            "failed",
            "blocked",
            "needs_approval",
            "stopped",
            "cancelled"
          ],
          "additionalProperties": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      },
      "additionalProperties": false
    },
    "transition_policy": {
      "type": "object",
      "required": [
        "decision_authority",
        "proposal_mode",
        "proposal_source_nodes",
        "allowed_targets",
        "proposal_schema",
        "controller_validation",
        "fallback_node"
      ],
      "properties": {
        "decision_authority": { "const": "codex_host_controller" },
        "proposal_mode": { "enum": ["none", "model_proposal"] },
        "proposal_source_nodes": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "allowed_targets": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "proposal_schema": { "type": "object" },
        "controller_validation": { "const": "required" },
        "fallback_node": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "tools": {
      "type": "object",
      "required": ["contracts", "rollback_procedures", "permission_bindings", "side_effect_policies"],
      "properties": {
        "contracts": {
          "type": "array",
          "items": { "$ref": "#/$defs/tool_contract" }
        },
        "rollback_procedures": { "type": "array" },
        "permission_bindings": { "type": "array" },
        "side_effect_policies": { "type": "array" }
      },
      "additionalProperties": false
    },
    "evaluation": {
      "type": "object",
      "properties": {
        "criteria_bindings": {
          "type": "array",
          "items": { "$ref": "#/$defs/criteria_binding" }
        }
      },
      "additionalProperties": true
    },
    "termination": { "type": "object" },
    "termination_control": {
      "type": "object",
      "required": [
        "policy_authority",
        "evaluation_authority",
        "reviewer_authority",
        "transition_policy",
        "hard_stop_precedence"
      ],
      "properties": {
        "policy_authority": { "const": "loop_spec" },
        "evaluation_authority": { "const": "codex_host_controller" },
        "reviewer_authority": { "const": "evidence_only" },
        "transition_policy": { "const": "lower_first_then_first_match" },
        "hard_stop_precedence": {
          "type": "array",
          "prefixItems": [
            { "const": "policy_violation" },
            { "const": "user_interrupt" },
            { "const": "max_runtime_seconds" },
            { "const": "max_iterations" },
            { "const": "max_token_budget" },
            { "const": "max_no_progress_loops" }
          ],
          "items": false,
          "minItems": 6
        }
      },
      "additionalProperties": false
    },
    "policy_registry": { "type": "object" },
    "policies": { "type": "object" },
    "delegation": {
      "type": "object",
      "required": ["agent_registry"],
      "properties": {
        "agent_registry": {
          "type": "array",
          "items": { "$ref": "#/$defs/agent_registry_entry" },
          "uniqueItems": true
        }
      },
      "additionalProperties": true
    },
    "artifacts": { "type": "object" },
    "threshold_register": {
      "type": "array",
      "items": { "$ref": "#/$defs/threshold" }
    },
    "validation": {
      "type": "object",
      "required": ["schema_version", "required_checks"],
      "properties": {
        "schema_version": { "const": "loop-spec-v4" },
        "required_checks": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false,
  "$defs": {
    "capability_requirements": {
      "type": "object",
      "properties": {
        "available_tools": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "tool_access_modes": {
          "type": "object",
          "additionalProperties": {
            "enum": ["read_only", "workspace_write", "external_write"]
          }
        },
        "durable_state": { "type": "boolean" },
        "checkpoint_resume": { "type": "boolean" },
        "sandbox": { "type": "boolean" },
        "human_interrupt": { "type": "boolean" },
        "parallel_execution": { "type": "boolean" },
        "subagents": { "type": "boolean" },
        "required_subagent_reasoning_intensity": {
          "type": ["string", "null"],
          "enum": ["extended_thought", null]
        }
      },
      "additionalProperties": false
    },
    "tool_contract": {
      "type": "object",
      "required": ["id", "side_effect", "access_mode", "controller_executes"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "side_effect": { "type": "string", "minLength": 1 },
        "access_mode": { "enum": ["read_only", "workspace_write", "external_write"] },
        "controller_executes": { "const": true }
      },
      "additionalProperties": true
    },
    "agent_registry_entry": {
      "type": "object",
      "required": [
        "id",
        "display_name",
        "specialization",
        "governance_role",
        "rationale",
        "prompt_ref",
        "activation_policy",
        "activation_nodes",
        "allowed_tools"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
        },
        "display_name": { "type": "string", "minLength": 1 },
        "specialization": { "type": "string", "minLength": 1 },
        "governance_role": {
          "enum": ["planner", "implementer", "reviewer", "verifier"]
        },
        "rationale": { "type": "string", "minLength": 1 },
        "prompt_ref": {
          "type": "string",
          "pattern": "^\\.codex-loop/subagents/[a-z0-9]+(?:-[a-z0-9]+)*\\.md$"
        },
        "activation_policy": { "const": "on_demand" },
        "activation_nodes": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "allowed_tools": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    },
    "node": {
      "type": "object",
      "required": [
        "id",
        "kind",
        "role",
        "objective",
        "input_schema",
        "output_schema",
        "allowed_tools",
        "state_read_scope",
        "state_write_scope"
      ],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "kind": {
          "enum": [
            "deterministic",
            "model",
            "tool",
            "worker",
            "approval",
            "merge",
            "terminal"
          ]
        },
        "role": {
          "enum": ["planner", "implementer", "reviewer", "verifier", "terminal"]
        },
        "agent_ref": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
        },
        "objective": { "type": "string", "minLength": 1 },
        "supports_acceptance_criteria": { "type": "array" },
        "input_schema": { "type": "object" },
        "output_schema": { "type": "object" },
        "allowed_tools": { "type": "array" },
        "state_read_scope": { "type": "array" },
        "state_write_scope": { "type": "array" },
        "evaluator_refs": { "type": "array" },
        "retry_policy_ref": { "type": ["string", "null"] },
        "timeout_policy_ref": { "type": ["string", "null"] },
        "checkpoint_before": { "type": "boolean" },
        "checkpoint_after": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "edge": {
      "type": "object",
      "required": ["from", "to", "condition", "priority"],
      "properties": {
        "from": { "type": "string", "minLength": 1 },
        "to": { "type": "string", "minLength": 1 },
        "condition": { "$ref": "#/$defs/condition" },
        "priority": { "type": "integer" },
        "tie_breaker": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "criteria_binding": {
      "type": "object",
      "required": ["criterion_id", "evaluator_ref", "subject_nodes"],
      "properties": {
        "criterion_id": { "type": "string", "minLength": 1 },
        "evaluator_ref": { "type": "string", "minLength": 1 },
        "evaluator_node": { "type": "string", "minLength": 1 },
        "subject_nodes": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        }
      },
      "additionalProperties": true
    },
    "cycle": {
      "type": "object",
      "required": [
        "id",
        "node_ids",
        "progress_signals",
        "stagnation_policy_ref",
        "budget_policy_ref",
        "exit_conditions"
      ],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "node_ids": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" },
          "uniqueItems": true
        },
        "progress_signals": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/progress_signal" }
        },
        "stagnation_policy_ref": { "type": "string", "minLength": 1 },
        "budget_policy_ref": { "type": "string", "minLength": 1 },
        "exit_conditions": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/condition" }
        }
      },
      "additionalProperties": false
    },
    "condition": {
      "type": "object",
      "oneOf": [
        { "required": ["all"], "not": { "required": ["any"] } },
        { "required": ["any"], "not": { "required": ["all"] } }
      ],
      "properties": {
        "all": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/predicate" } },
        "any": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/predicate" } }
      },
      "additionalProperties": false
    },
    "predicate": {
      "type": "object",
      "required": ["fact", "operator"],
      "properties": {
        "fact": { "type": "string", "pattern": "^(state|controller)\\." },
        "operator": { "enum": ["eq", "ne", "gt", "gte", "lt", "lte", "in", "not_in", "contains", "is_true", "is_false", "is_empty", "is_not_empty"] },
        "value": {}
      },
      "additionalProperties": false
    },
    "progress_signal": {
      "type": "object",
      "required": ["fact", "operator", "evidence_ref"],
      "properties": {
        "fact": { "type": "string", "pattern": "^(state|controller)\\." },
        "operator": { "enum": ["increases", "decreases", "changes", "new_unique_item"] },
        "evidence_ref": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "threshold": {
      "type": "object",
      "required": [
        "id",
        "value",
        "unit",
        "source",
        "rationale",
        "calibration_scope",
        "review_trigger"
      ],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "value": { "type": ["number", "integer"] },
        "unit": { "type": "string", "minLength": 1 },
        "source": { "type": "string", "minLength": 1 },
        "rationale": { "type": "string", "minLength": 1 },
        "calibration_scope": { "type": "string", "minLength": 1 },
        "review_trigger": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    }
  }
}
