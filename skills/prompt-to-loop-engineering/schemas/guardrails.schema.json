{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://meta-skills-library.dev/schemas/guardrails.schema.json",
  "title": "Codex Loop Guardrails",
  "type": "object",
  "required": [
    "schema_version",
    "guardrail_set_id",
    "forbidden_commands",
    "write_boundaries",
    "approval_required_actions",
    "stop_conditions"
  ],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "guardrail_set_id": {
      "type": "string",
      "pattern": "^[a-zA-Z0-9][a-zA-Z0-9_.:@-]*$"
    },
    "forbidden_commands": {
      "type": "array",
      "items": { "$ref": "#/$defs/guardrail_rule" },
      "uniqueItems": true
    },
    "write_boundaries": {
      "type": "array",
      "items": { "$ref": "#/$defs/write_boundary" },
      "uniqueItems": true
    },
    "approval_required_actions": {
      "type": "array",
      "items": { "$ref": "#/$defs/guardrail_rule" },
      "uniqueItems": true
    },
    "stop_conditions": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/guardrail_rule" },
      "uniqueItems": true
    }
  },
  "additionalProperties": false,
  "$defs": {
    "guardrail_rule": {
      "type": "object",
      "required": ["id", "description", "match"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-zA-Z0-9][a-zA-Z0-9_.:@-]*$"
        },
        "description": { "type": "string", "minLength": 1 },
        "match": {
          "type": "object",
          "required": ["type", "value"],
          "properties": {
            "type": { "enum": ["command_prefix", "path_glob", "condition"] },
            "value": { "type": "string", "minLength": 1 }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "write_boundary": {
      "type": "object",
      "required": ["id", "path", "mode"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-zA-Z0-9][a-zA-Z0-9_.:@-]*$"
        },
        "path": { "type": "string", "minLength": 1 },
        "mode": { "enum": ["read_only", "workspace_write", "approval_required"] }
      },
      "additionalProperties": false
    }
  }
}
