{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://meta-skills-library.dev/schemas/agent_manifest.schema.json",
  "title": "Codex Agent Manifest",
  "type": "object",
  "required": [
    "schema_version",
    "manifest_id",
    "created_by_skill",
    "codex_host",
    "task_binding",
    "loop_binding",
    "guardrails_ref",
    "governance_overlay",
    "subagents",
    "tool_bindings",
    "knowledge_bindings",
    "resume_policy"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "manifest_id": {
      "type": "string",
      "pattern": "^[a-zA-Z0-9][a-zA-Z0-9_.:@-]*$"
    },
    "created_by_skill": {
      "type": "object",
      "required": ["name", "version"],
      "properties": {
        "name": { "const": "prompt-to-loop-engineering" },
        "version": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
        }
      },
      "additionalProperties": false
    },
    "codex_host": {
      "type": "object",
      "required": [
        "executor",
        "independent_runtime_engine",
        "execution_boundary"
      ],
      "properties": {
        "executor": { "const": "codex" },
        "independent_runtime_engine": { "const": false },
        "execution_boundary": {
          "const": "Codex reads the persisted scaffold and advances work only under the active user/session permissions."
        }
      },
      "additionalProperties": false
    },
    "task_binding": {
      "type": "object",
      "required": ["request_id", "design_result_ref", "loop_spec_ref"],
      "properties": {
        "request_id": { "type": "string", "minLength": 1 },
        "design_result_ref": { "$ref": "#/$defs/relative_path" },
        "loop_spec_ref": { "const": ".codex-loop/loop_spec.json" }
      },
      "additionalProperties": false
    },
    "loop_binding": {
      "type": "object",
      "required": [
        "loop_spec_path",
        "status_path",
        "status_format",
        "resume_entry_policy"
      ],
      "properties": {
        "loop_spec_path": { "const": ".codex-loop/loop_spec.json" },
        "status_path": { "const": ".codex-loop/.status" },
        "status_format": { "const": "single_current_stage_id" },
        "resume_entry_policy": {
          "enum": ["read_status_then_validate_stage", "start_at_loop_entry_when_status_missing"]
        }
      },
      "additionalProperties": false
    },
    "guardrails_ref": {
      "const": ".codex-loop/guardrails.json"
    },
    "governance_overlay": {
      "type": "object",
      "required": [
        "runtime_mode",
        "dag_scheduler_owner",
        "host_linear_fulfillment_takeover",
        "specialized_skills_policy",
        "evidence_root",
        "post_hoc_validator",
        "required_evidence_refs"
      ],
      "properties": {
        "runtime_mode": { "const": "COOPERATIVE_GOVERNANCE" },
        "dag_scheduler_owner": { "const": "prompt-to-loop-engineering" },
        "host_linear_fulfillment_takeover": { "const": "forbidden" },
        "specialized_skills_policy": { "const": "node_scoped_atomic_capabilities" },
        "evidence_root": { "const": ".codex-loop/evidence" },
        "post_hoc_validator": { "const": "validate_dag_execution_evidence.py" },
        "required_evidence_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^\\.codex-loop/evidence/(activation|handoff|completion)/[A-Za-z0-9_.:@-]+\\.json$"
          },
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    },
    "subagents": {
      "type": "array",
      "minItems": 1,
      "maxItems": 3,
      "items": { "$ref": "#/$defs/subagent" },
      "uniqueItems": true
    },
    "tool_bindings": {
      "type": "array",
      "items": { "$ref": "#/$defs/tool_binding" },
      "uniqueItems": true
    },
    "knowledge_bindings": {
      "type": "array",
      "items": { "$ref": "#/$defs/knowledge_binding" },
      "uniqueItems": true
    },
    "resume_policy": {
      "type": "object",
      "required": [
        "context_source_order",
        "missing_status_behavior",
        "forbidden_resume_behavior"
      ],
      "properties": {
        "context_source_order": {
          "type": "array",
          "minItems": 3,
          "items": {
            "enum": [
              ".codex-loop/agent_manifest.json",
              ".codex-loop/loop_spec.json",
              ".codex-loop/guardrails.json",
              ".codex-loop/.status",
              ".codex-loop/subagents/"
            ]
          },
          "uniqueItems": true
        },
        "missing_status_behavior": {
          "enum": ["start_at_entry_node", "ask_user"]
        },
        "forbidden_resume_behavior": {
          "const": "stop_and_report_guardrail_violation"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false,
  "$defs": {
    "relative_path": {
      "type": "string",
      "pattern": "^(?![a-zA-Z]:)(?!/)(?!.*\\.\\.).+"
    },
    "subagent": {
      "type": "object",
      "required": [
        "id",
        "prompt_path",
        "activation_nodes",
        "responsibilities",
        "allowed_tools",
        "output_contract"
      ],
      "properties": {
        "id": {
          "enum": ["planner", "executor", "reviewer"]
        },
        "prompt_path": {
          "enum": [
            ".codex-loop/subagents/planner.md",
            ".codex-loop/subagents/executor.md",
            ".codex-loop/subagents/reviewer.md"
          ]
        },
        "activation_nodes": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "responsibilities": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "allowed_tools": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "output_contract": {
          "type": "object",
          "required": ["format", "required_fields"],
          "properties": {
            "format": { "enum": ["markdown", "json"] },
            "required_fields": {
              "type": "array",
              "minItems": 1,
              "items": { "type": "string", "minLength": 1 },
              "uniqueItems": true
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "tool_binding": {
      "type": "object",
      "required": ["name", "purpose", "permission_mode", "guardrail_refs"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "purpose": { "type": "string", "minLength": 1 },
        "permission_mode": {
          "enum": ["read_only", "workspace_write", "approval_required"]
        },
        "guardrail_refs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    },
    "knowledge_binding": {
      "type": "object",
      "required": ["id", "source_ref", "access_mode", "provenance_required"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "source_ref": { "$ref": "#/$defs/relative_path" },
        "access_mode": { "enum": ["read_only"] },
        "provenance_required": { "const": true }
      },
      "additionalProperties": false
    }
  }
}
