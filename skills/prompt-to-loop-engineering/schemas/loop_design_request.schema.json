{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://meta-skills-library.dev/schemas/loop_design_request.schema.json",
  "title": "Loop Design Request",
  "type": "object",
  "required": [
    "request_id",
    "task_prompt",
    "known_context",
    "runtime_capabilities",
    "policy_constraints",
    "budget_envelope",
    "output_requirements"
  ],
  "properties": {
    "request_id": {
      "type": "string",
      "minLength": 1
    },
    "task_prompt": {
      "type": "string",
      "minLength": 1
    },
    "known_context": {
      "type": "array"
    },
    "runtime_capabilities": {
      "type": "object",
      "required": [
        "available_tools",
        "tool_access_modes",
        "durable_state",
        "checkpoint_resume",
        "sandbox",
        "human_interrupt",
        "parallel_execution",
        "subagents",
        "required_subagent_reasoning_intensity"
      ],
      "properties": {
        "available_tools": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "tool_access_modes": {
          "type": "object",
          "additionalProperties": {
            "enum": ["read_only", "workspace_write", "external_write"]
          }
        },
        "durable_state": { "type": "boolean", "default": false },
        "checkpoint_resume": { "type": "boolean", "default": false },
        "sandbox": { "type": "boolean", "default": false },
        "human_interrupt": { "type": "boolean", "default": false },
        "parallel_execution": { "type": "boolean", "default": false },
        "subagents": {
          "type": "boolean",
          "default": false,
          "description": "Host-native sub-agent lifecycle capability. Before setting false, the builder must probe tool discovery for spawn_agent, spawn_subagent, subagent, and multi_agent and preserve no_host_native_lifecycle_tool_found evidence."
        },
        "required_subagent_reasoning_intensity": {
          "type": ["string", "null"],
          "enum": ["extended_thought", null],
          "default": null,
          "description": "Required child-agent reasoning profile for host-native subagent activation. Use extended_thought when subagents are relied on for complex reasoning."
        }
      },
      "additionalProperties": false
    },
    "policy_constraints": {
      "type": "object",
      "required": [
        "allowed_side_effects",
        "forbidden_actions",
        "approval_rules"
      ],
      "properties": {
        "allowed_side_effects": { "type": "array" },
        "forbidden_actions": { "type": "array" },
        "approval_rules": { "type": "array" }
      },
      "additionalProperties": false
    },
    "budget_envelope": {
      "type": "object",
      "description": "Strict effective-request budget. Raw requests may omit these values only before deterministic normalization by scripts/normalize_design_request.py.",
      "required": [
        "max_runtime_seconds",
        "max_iterations",
        "max_token_budget",
        "max_no_progress_loops"
      ],
      "properties": {
        "max_runtime_seconds": { "type": "integer", "minimum": 1 },
        "max_iterations": { "type": "integer", "minimum": 1 },
        "max_token_budget": { "type": "integer", "minimum": 1 },
        "max_no_progress_loops": { "type": "integer", "minimum": 1 }
      },
      "additionalProperties": true
    },
    "output_requirements": {
      "type": "object"
    }
  },
  "additionalProperties": false
}
