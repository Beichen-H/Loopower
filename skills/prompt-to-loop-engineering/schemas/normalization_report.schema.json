{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://meta-skills-library.dev/schemas/normalization_report.schema.json",
  "title": "Loop Design Request Normalization Report v2",
  "type": "object",
  "required": [
    "schema_version", "normalizer_version", "default_policy_id",
    "raw_request_hash", "effective_request_hash", "defaults_applied",
    "explicit_budget_fields", "source_preserved"
  ],
  "properties": {
    "schema_version": { "const": "2.0.0" },
    "normalizer_version": { "const": "2.0.0" },
    "default_policy_id": { "const": "codex-native-safe-v1" },
    "raw_request_hash": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "effective_request_hash": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "defaults_applied": {
      "type": "object",
      "additionalProperties": { "type": "integer", "minimum": 1 }
    },
    "explicit_budget_fields": {
      "type": "array",
      "items": { "type": "string" },
      "uniqueItems": true
    },
    "source_preserved": { "const": true }
  },
  "additionalProperties": false
}
