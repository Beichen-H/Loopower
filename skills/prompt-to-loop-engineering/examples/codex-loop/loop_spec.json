{
  "spec_id": "codex-native-feature-loop@1",
  "version": 1,
  "created_from_request": "example-codex-loop-scaffold",
  "task_contract_ref": "codex-native-feature-loop@1",
  "architecture": {
    "mode": "agent_loop",
    "execution_patterns": ["plan_execute_replan", "tool_use", "evaluator_optimizer"],
    "topology": {"type": "orchestrator_workers", "parallel_mode": null},
    "control_gates": ["policy_check", "independent_review"],
    "domain_compositions": ["codex_project_feature_delivery"],
    "cross_cutting_policies": ["observability", "budget_control", "scope_control"],
    "rationale": "Codex coordinates a compact planner/executor loop and reads persisted prompts when each specialization is needed."
  },
  "runtime_binding": {
    "capabilities_snapshot": {
      "available_tools": ["read_files", "edit_files", "run_tests"],
      "durable_state": false,
      "checkpoint_resume": false,
      "sandbox": true,
      "human_interrupt": true,
      "parallel_execution": false,
      "subagents": true,
      "required_subagent_reasoning_intensity": "extended_thought"
    },
    "required_capabilities": {
      "available_tools": ["read_files", "edit_files", "run_tests"],
      "sandbox": true,
      "human_interrupt": true,
      "subagents": true,
      "required_subagent_reasoning_intensity": "extended_thought"
    },
    "capability_mismatches": []
  },
  "execution_governance": {
    "runtime_mode": "COOPERATIVE_GOVERNANCE",
    "scheduler": "codex_loop_dag",
    "inline_execution_policy": "forbidden_for_subagent_nodes",
    "required_evidence": {
      "activation": true,
      "handoff": true,
      "completion": true
    },
    "linear_fulfillment_plugins": {
      "scheduler_takeover": "forbidden",
      "allowed_role": "node_scoped_atomic_capability"
    }
  },
  "state": {
    "schema": {
      "current_stage": "string",
      "plan_ready": "boolean",
      "implementation_ready": "boolean",
      "validation_passed": "boolean",
      "diff_fingerprint": "string",
      "test_count": "integer",
      "artifact_hash": "string",
      "new_evidence_count": "integer",
      "budget_remaining": "integer"
    },
    "initial_state": {
      "current_stage": "planner",
      "plan_ready": false,
      "implementation_ready": false,
      "validation_passed": false,
      "diff_fingerprint": "",
      "test_count": 0,
      "artifact_hash": "",
      "new_evidence_count": 0,
      "budget_remaining": 5
    },
    "persistence": "status_file",
    "state_version": 1,
    "reducers": [],
    "controller_owned_fields": ["current_stage", "validation_passed", "budget_remaining", "diff_fingerprint", "test_count", "artifact_hash", "new_evidence_count"],
    "write_conflict_policy": "single-writer-per-field"
  },
  "control_flow": {
    "entry_node": "planner",
    "edge_selection_policy": {
      "priority_order": "lower_first",
      "match_policy": "first_match",
      "equal_priority": "require_explicit_tie_breaker"
    },
    "nodes": [
      {"id": "planner", "kind": "model", "role": "planner", "objective": "Read the project context and produce a bounded implementation plan.", "allowed_tools": ["read_files"]},
      {"id": "executor", "kind": "model", "role": "implementer", "objective": "Apply the approved plan inside the declared write boundaries.", "allowed_tools": ["read_files", "edit_files", "run_tests"]},
      {"id": "terminal_export", "kind": "terminal", "role": "verifier", "objective": "Export completion, blocked, or stopped status with validation evidence.", "allowed_tools": []}
    ],
    "edges": [
      {"from": "planner", "to": "executor", "condition": {"all": [{"fact": "state.plan_ready", "operator": "eq", "value": true}]}, "priority": 10},
      {"from": "executor", "to": "planner", "condition": {"all": [{"fact": "state.validation_passed", "operator": "eq", "value": false}, {"fact": "state.budget_remaining", "operator": "gt", "value": 0}]}, "priority": 20},
      {"from": "executor", "to": "terminal_export", "condition": {"any": [{"fact": "state.validation_passed", "operator": "eq", "value": true}, {"fact": "state.budget_remaining", "operator": "eq", "value": 0}]}, "priority": 30}
    ],
    "cycles": [
      {
        "id": "bounded_plan_execute_cycle",
        "node_ids": ["planner", "executor"],
        "progress_signals": [
          {"fact": "state.implementation_ready", "operator": "changes", "evidence_ref": "test_or_diff_evidence"},
          {"fact": "state.diff_fingerprint", "operator": "changes", "evidence_ref": "progress_fingerprint"}
        ],
        "stagnation_policy_ref": "no_new_diff_after_two_cycles",
        "budget_policy_ref": "loop_iteration_budget",
        "exit_conditions": [
          {"all": [{"fact": "state.validation_passed", "operator": "eq", "value": true}]},
          {"all": [{"fact": "state.budget_remaining", "operator": "eq", "value": 0}]}
        ]
      }
    ],
    "terminal_nodes": {"passed": ["terminal_export"], "failed": [], "blocked": [], "needs_approval": [], "stopped": ["terminal_export"], "cancelled": []}
  },
  "threshold_register": [
    {"id": "max_runtime_seconds", "value": 900, "unit": "seconds", "source": "defensive_default", "rationale": "Hard wall-clock stop for Codex-native scaffold execution.", "calibration_scope": "bounded_plan_execute_cycle", "review_trigger": "runtime budget changes"},
    {"id": "max_iterations", "value": 3, "unit": "iterations", "source": "defensive_default", "rationale": "Hard iteration stop for Codex-native scaffold execution.", "calibration_scope": "bounded_plan_execute_cycle", "review_trigger": "iteration budget changes"},
    {"id": "max_token_budget", "value": 120000, "unit": "tokens", "source": "defensive_default", "rationale": "Hard token budget stop for Codex-native scaffold execution.", "calibration_scope": "bounded_plan_execute_cycle", "review_trigger": "token budget changes"},
    {"id": "max_no_progress_loops", "value": 1, "unit": "loops", "source": "defensive_default", "rationale": "Stop when consecutive progress fingerprints show no material change.", "calibration_scope": "bounded_plan_execute_cycle", "review_trigger": "stagnation tolerance changes"}
  ]
}
