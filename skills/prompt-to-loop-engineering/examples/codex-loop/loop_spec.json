{
  "spec_id": "codex-native-feature-loop@1",
  "version": 1,
  "created_from_request": "example-codex-loop-scaffold",
  "task_contract_ref": "codex-native-feature-loop@1",
  "architecture": {
    "mode": "agent_loop",
    "execution_patterns": ["plan_execute_replan", "tool_use", "evaluator_optimizer"],
    "topology": {"type": "orchestrator_workers", "parallel_mode": null},
    "control_gates": ["policy_check", "independent_review"],
    "domain_compositions": ["codex_project_feature_delivery"],
    "cross_cutting_policies": ["observability", "budget_control", "scope_control"],
    "rationale": "Codex activates four task-specific roles on demand in a strictly sequential feature-delivery loop."
  },
  "runtime_binding": {
    "capabilities_snapshot": {
      "available_tools": ["read_files", "edit_files", "run_tests"],
      "tool_access_modes": {"read_files": "read_only", "edit_files": "workspace_write", "run_tests": "read_only"},
      "durable_state": false,
      "checkpoint_resume": false,
      "sandbox": true,
      "human_interrupt": true,
      "parallel_execution": false,
      "subagents": true,
      "required_subagent_reasoning_intensity": "extended_thought"
    },
    "required_capabilities": {
      "available_tools": ["read_files", "edit_files", "run_tests"],
      "tool_access_modes": {"read_files": "read_only", "edit_files": "workspace_write", "run_tests": "read_only"},
      "sandbox": true,
      "human_interrupt": true,
      "subagents": true,
      "required_subagent_reasoning_intensity": "extended_thought"
    },
    "capability_mismatches": []
  },
  "execution_governance": {
    "runtime_mode": "COOPERATIVE_GOVERNANCE",
    "scheduler": "codex_loop_dag",
    "inline_execution_policy": "forbidden_for_subagent_nodes",
    "required_evidence": {
      "activation": true,
      "handoff": true,
      "completion": true
    },
    "linear_fulfillment_plugins": {
      "scheduler_takeover": "forbidden",
      "allowed_role": "node_scoped_atomic_capability"
    }
  },
  "state": {
    "schema": {
      "current_stage": "string",
      "plan_ready": "boolean",
      "implementation_ready": "boolean",
      "validation_passed": "boolean",
      "diff_fingerprint": "string",
      "test_count": "integer",
      "artifact_hash": "string",
      "new_evidence_count": "integer",
      "budget_remaining": "integer"
    },
    "initial_state": {
      "current_stage": "requirements-analysis",
      "plan_ready": false,
      "implementation_ready": false,
      "validation_passed": false,
      "diff_fingerprint": "",
      "test_count": 0,
      "artifact_hash": "",
      "new_evidence_count": 0,
      "budget_remaining": 5
    },
    "persistence": "status_file",
    "state_version": 1,
    "reducers": [],
    "controller_owned_fields": ["current_stage", "validation_passed", "budget_remaining", "diff_fingerprint", "test_count", "artifact_hash", "new_evidence_count"],
    "write_conflict_policy": "single-writer-per-field"
  },
  "control_flow": {
    "entry_node": "requirements-analysis",
    "edge_selection_policy": {
      "priority_order": "lower_first",
      "match_policy": "first_match",
      "equal_priority": "require_explicit_tie_breaker"
    },
    "nodes": [
      {"id": "requirements-analysis", "kind": "model", "role": "planner", "agent_ref": "requirements-analyst", "objective": "Produce bounded requirements and acceptance criteria.", "allowed_tools": ["read_files"]},
      {"id": "feature-implementation", "kind": "model", "role": "implementer", "agent_ref": "feature-engineer", "objective": "Implement the approved requirements inside the workspace boundary.", "allowed_tools": ["read_files", "edit_files", "run_tests"]},
      {"id": "test-verification", "kind": "model", "role": "verifier", "agent_ref": "test-verifier", "objective": "Independently verify test and acceptance evidence without editing.", "allowed_tools": ["read_files", "run_tests"]},
      {"id": "security-review", "kind": "model", "role": "reviewer", "agent_ref": "security-auditor", "objective": "Independently review the verified change for security regressions.", "allowed_tools": ["read_files"]},
      {"id": "terminal-export", "kind": "terminal", "role": "terminal", "objective": "Export controller-decided successful completion.", "allowed_tools": []},
      {"id": "terminal-stopped", "kind": "terminal", "role": "terminal", "objective": "Export a controller-enforced hard stop.", "allowed_tools": []}
    ],
    "edges": [
      {"from": "requirements-analysis", "to": "feature-implementation", "condition": {"all": [{"fact": "state.plan_ready", "operator": "eq", "value": true}]}, "priority": 10},
      {"from": "feature-implementation", "to": "test-verification", "condition": {"all": [{"fact": "state.implementation_ready", "operator": "eq", "value": true}]}, "priority": 10},
      {"from": "test-verification", "to": "security-review", "condition": {"all": [{"fact": "state.validation_passed", "operator": "eq", "value": true}]}, "priority": 10},
      {"from": "security-review", "to": "terminal-export", "condition": {"all": [{"fact": "state.validation_passed", "operator": "eq", "value": true}]}, "priority": 10},
      {"from": "security-review", "to": "terminal-stopped", "condition": {"all": [{"fact": "state.budget_remaining", "operator": "eq", "value": 0}]}, "priority": 20}
    ],
    "cycles": [
      {
        "id": "bounded_feature_delivery_cycle",
        "node_ids": ["requirements-analysis", "feature-implementation", "test-verification", "security-review"],
        "progress_signals": [
          {"fact": "state.implementation_ready", "operator": "changes", "evidence_ref": "test_or_diff_evidence"},
          {"fact": "state.diff_fingerprint", "operator": "changes", "evidence_ref": "progress_fingerprint"}
        ],
        "stagnation_policy_ref": "no_new_diff_after_two_cycles",
        "budget_policy_ref": "loop_iteration_budget",
        "exit_conditions": [
          {"all": [{"fact": "state.validation_passed", "operator": "eq", "value": true}]},
          {"all": [{"fact": "state.budget_remaining", "operator": "eq", "value": 0}]}
        ]
      }
    ],
    "terminal_nodes": {"passed": ["terminal-export"], "failed": [], "blocked": [], "needs_approval": [], "stopped": ["terminal-stopped"], "cancelled": []}
  },
  "transition_policy": {
    "decision_authority": "codex_host_controller",
    "proposal_mode": "model_proposal",
    "proposal_source_nodes": ["requirements-analysis", "feature-implementation"],
    "allowed_targets": ["requirements-analysis", "feature-implementation", "test-verification", "security-review", "terminal-export", "terminal-stopped"],
    "proposal_schema": {"next_node": "string", "reason_summary": "string"},
    "controller_validation": "required",
    "fallback_node": "terminal-stopped"
  },
  "termination_control": {
    "policy_authority": "loop_spec",
    "evaluation_authority": "codex_host_controller",
    "reviewer_authority": "evidence_only",
    "transition_policy": "lower_first_then_first_match",
    "hard_stop_precedence": ["policy_violation", "user_interrupt", "max_runtime_seconds", "max_iterations", "max_token_budget", "max_no_progress_loops"]
  },
  "delegation": {
    "agent_registry": [
      {"id": "requirements-analyst", "display_name": "Requirements Analyst", "specialization": "requirements-analysis", "governance_role": "planner", "rationale": "A dedicated planner converts the request into bounded acceptance criteria before implementation.", "prompt_ref": ".codex-loop/subagents/requirements-analyst.md", "activation_policy": "on_demand", "activation_nodes": ["requirements-analysis"], "allowed_tools": ["read_files"]},
      {"id": "feature-engineer", "display_name": "Feature Engineer", "specialization": "feature-implementation", "governance_role": "implementer", "rationale": "A focused implementer applies the approved requirements within the workspace boundary.", "prompt_ref": ".codex-loop/subagents/feature-engineer.md", "activation_policy": "on_demand", "activation_nodes": ["feature-implementation"], "allowed_tools": ["read_files", "edit_files", "run_tests"]},
      {"id": "test-verifier", "display_name": "Test Verifier", "specialization": "test-evidence-verification", "governance_role": "verifier", "rationale": "Independent read-only test verification prevents the implementer from evaluating its own work.", "prompt_ref": ".codex-loop/subagents/test-verifier.md", "activation_policy": "on_demand", "activation_nodes": ["test-verification"], "allowed_tools": ["read_files", "run_tests"]},
      {"id": "security-auditor", "display_name": "Security Auditor", "specialization": "security-review", "governance_role": "reviewer", "rationale": "An independent read-only reviewer checks the verified change for security regressions.", "prompt_ref": ".codex-loop/subagents/security-auditor.md", "activation_policy": "on_demand", "activation_nodes": ["security-review"], "allowed_tools": ["read_files"]}
    ]
  },
  "threshold_register": [
    {"id": "max_runtime_seconds", "value": 900, "unit": "seconds", "source": "default_policy:codex-native-safe-v1", "rationale": "Hard wall-clock stop for Codex-native scaffold execution.", "calibration_scope": "bounded_feature_delivery_cycle", "review_trigger": "runtime budget changes"},
    {"id": "max_iterations", "value": 3, "unit": "iterations", "source": "default_policy:codex-native-safe-v1", "rationale": "Hard iteration stop for Codex-native scaffold execution.", "calibration_scope": "bounded_feature_delivery_cycle", "review_trigger": "iteration budget changes"},
    {"id": "max_token_budget", "value": 45000, "unit": "tokens", "source": "default_policy:codex-native-safe-v1", "rationale": "Hard token budget stop for Codex-native scaffold execution.", "calibration_scope": "bounded_feature_delivery_cycle", "review_trigger": "token budget changes"},
    {"id": "max_no_progress_loops", "value": 1, "unit": "loops", "source": "default_policy:codex-native-safe-v1", "rationale": "Stop when consecutive progress fingerprints show no material change.", "calibration_scope": "bounded_feature_delivery_cycle", "review_trigger": "stagnation tolerance changes"}
  ]
}
